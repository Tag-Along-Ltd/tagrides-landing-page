# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# netlify (local build cache + functions bundle — generated by CLI / build plugin)
.netlify/

# claude code (local agent state — settings, transcripts, project memory)
.claude/

# Pre-crop originals for pitch headshots — kept locally so we can
# re-frame later if a face crop needs adjusting, but not shipped.
public/assets/pitch/*-orig.*

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright mcp screenshots/snapshots
.playwright-mcp/


# Playwright visual-iteration screenshots (kept locally as design artifacts)
slide-*.png
v[0-9]*.png
web-*.png
